<section class="mvpt-container mvpt-hero" id="hero">
  <div>
    <span class="mvpt-eyebrow">{{ home.hero.eyebrow }}</span>
    <h1 class="mvpt-hero__title">{{ home.hero.title }}</h1>
    <p class="mvpt-hero__sublocation">{{ home.hero.sublocation }}</p>
    <p class="mvpt-hero__lede">{{ home.hero.lede | safe }}</p>
    <div class="mvpt-hero__actions">
      <a href="{{ home.hero.primaryCta.href }}" class="mvpt-btn mvpt-btn--solid mvpt-btn--lg">{{ home.hero.primaryCta.label }}</a>
      <a href="{{ home.hero.secondaryCta.href }}" class="mvpt-btn mvpt-btn--lg">{{ home.hero.secondaryCta.label }}</a>
    </div>
    <ul class="mvpt-hero__marks">
      {% for mark in home.hero.marks %}
      <li>{{ mark }}</li>
      {% endfor %}
    </ul>
  </div>
  <div class="mvpt-hero__media">
    <video id="mvpt-hero-video" autoplay loop muted playsinline
           poster="hero_page.jpg"
           preload="auto"
           data-src-hi="hero_page.mp4"
           width="1920" height="1080"
           aria-label="Michael demonstrating Functional Patterns movement">
      <source src="hero_page_low.mp4" type="video/mp4">
      Your browser does not support the video tag.
    </video>
  </div>
</section>
<script>
(function() {
  var v = document.getElementById('mvpt-hero-video');
  if (!v) return;
  var hi = v.getAttribute('data-src-hi');
  if (!hi) return;

  function swap() {
    var pre = document.createElement('video');
    pre.preload = 'auto';
    pre.muted = true;
    pre.src = hi;
    pre.addEventListener('canplaythrough', function() {
      var t = v.currentTime;
      var src = v.querySelector('source');
      if (src) src.src = hi; else v.src = hi;
      v.load();
      var resume = function() {
        try { v.currentTime = t % (v.duration || t); } catch (e) {}
        var p = v.play();
        if (p && p.catch) p.catch(function(){});
      };
      if (v.readyState >= 2) resume();
      else v.addEventListener('loadeddata', resume, { once: true });
    }, { once: true });
    pre.addEventListener('error', function() {}, { once: true });
  }

  if (!v.paused && v.currentTime > 0) swap();
  else v.addEventListener('playing', swap, { once: true });
})();
</script>
