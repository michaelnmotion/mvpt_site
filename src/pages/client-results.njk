<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('[data-carousel]').forEach(function(carousel) {
    var track = carousel.querySelector('.carousel-track');
    var dots = carousel.querySelectorAll('.carousel-dot');
    var totalReal = 4;
    var current = 0;
    var autoInterval = 4000;
    var timer;
    var isTransitioning = false;

    function slideWidth() {
      /* Each slide is 50% on desktop, 100% on mobile — read from CSS */
      return track.children[0].getBoundingClientRect().width;
    }

    function setPos(animate) {
      track.style.transition = animate
        ? 'transform 0.8s cubic-bezier(0.25, 0.1, 0.25, 1)'
        : 'none';
      track.style.transform = 'translateX(-' + (current * slideWidth()) + 'px)';
    }

    function setDots() {
      /* At current 0 we see slides 0+1, highlight dot 0.
         At current 3, we see slides 3+clone0, highlight dot 3.
         At current 4 (snap zone), highlight dot 0 briefly. */
      var idx = current % totalReal;
      dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
    }

    function advance() {
      if (isTransitioning) return;
      isTransitioning = true;
      current++;
      setPos(true);
      setDots();

      /* After scrolling to position 4, the viewport shows [clone0, clone1]
         which looks identical to position 0 [slide0, slide1]. Snap back. */
      if (current >= totalReal) {
        setTimeout(function() {
          current = 0;
          setPos(false);
          isTransitioning = false;
        }, 850);
      } else {
        setTimeout(function() { isTransitioning = false; }, 850);
      }
    }

    function goTo(i) {
      if (isTransitioning) return;
      isTransitioning = true;
      current = i;
      setPos(true);
      setDots();
      resetTimer();
      setTimeout(function() { isTransitioning = false; }, 850);
    }

    function resetTimer() {
      clearInterval(timer);
      timer = setInterval(advance, autoInterval);
    }

    dots.forEach(function(d, i) {
      d.addEventListener('click', function() { goTo(i); });
    });

    setPos(false);
    setDots();
    timer = setInterval(advance, autoInterval);

    carousel.addEventListener('mouseenter', function() { clearInterval(timer); });
    carousel.addEventListener('mouseleave', resetTimer);

    var rTimer;
    window.addEventListener('resize', function() {
      clearTimeout(rTimer);
      rTimer = setTimeout(function() { setPos(false); }, 100);
    });
  });
});
</script>
