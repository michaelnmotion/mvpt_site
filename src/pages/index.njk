<script>
document.addEventListener('DOMContentLoaded', function() {
  var carousel = document.querySelector('[data-rc-carousel]');
  if (!carousel) return;
  var track = carousel.querySelector('.rc-track');
  var cards = track.querySelectorAll('.rc-card');
  var cardCount = cards.length;

  // Clone all cards for seamless infinite loop
  cards.forEach(function(card) {
    track.appendChild(card.cloneNode(true));
  });

  // Measure one card width including gap
  function getCardWidth() {
    var card = track.querySelector('.rc-card');
    var style = getComputedStyle(track);
    var gap = parseFloat(style.gap) || 16;
    return card.offsetWidth + gap;
  }

  var scrollPos = 0;
  var velocity = 0;
  var targetVelocity = 0.2; // base auto-scroll speed (px/frame)
  var isHovering = false;
  var mouseXRatio = 0.5;
  var animId = null;
  var maxSpeed = 3;

  // Smooth seamless loop
  function wrapPosition() {
    var totalWidth = getCardWidth() * cardCount;
    if (scrollPos >= totalWidth) {
      scrollPos -= totalWidth;
    } else if (scrollPos < 0) {
      scrollPos += totalWidth;
    }
  }

  function animate() {
    if (isHovering) {
      // Map mouse X to velocity: left = scroll left (negative), right = scroll right (positive)
      // Center = slow/stopped
      var mapped = (mouseXRatio - 0.5) * 2; // -1 to 1
      var direction = mapped > 0 ? 1 : -1;
      var strength = Math.pow(Math.abs(mapped), 1.5); // exponential feel
      targetVelocity = direction * strength * maxSpeed;
    } else {
      targetVelocity = 0.5;
    }

    // Smooth velocity interpolation
    velocity += (targetVelocity - velocity) * 0.08;
    scrollPos += velocity;
    wrapPosition();

    track.style.transform = 'translate3d(' + (-scrollPos) + 'px, 0, 0)';
    animId = requestAnimationFrame(animate);
  }

  carousel.addEventListener('mouseenter', function() {
    isHovering = true;
  });

  carousel.addEventListener('mouseleave', function() {
    isHovering = false;
  });

  carousel.addEventListener('mousemove', function(e) {
    var rect = carousel.getBoundingClientRect();
    mouseXRatio = (e.clientX - rect.left) / rect.width;
  });

  // Touch support: swipe to scroll
  var touchStartX = 0;
  var touchScrollStart = 0;
  var isTouching = false;

  carousel.addEventListener('touchstart', function(e) {
    isTouching = true;
    isHovering = true;
    touchStartX = e.touches[0].clientX;
    touchScrollStart = scrollPos;
    targetVelocity = 0;
    velocity = 0;
  }, { passive: true });

  carousel.addEventListener('touchmove', function(e) {
    if (!isTouching) return;
    var dx = touchStartX - e.touches[0].clientX;
    scrollPos = touchScrollStart + dx;
    wrapPosition();
  }, { passive: true });

  carousel.addEventListener('touchend', function() {
    isTouching = false;
    isHovering = false;
  });

  // Start animation loop
  animId = requestAnimationFrame(animate);
});
</script>
